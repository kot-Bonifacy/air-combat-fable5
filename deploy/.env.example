# Faza 13: pełny stack (frontend + backend WS). Skopiuj do `.env` NA VPS (nie wersjonuj —
# patrz .gitignore). docker-compose czyta `.env` z katalogu compose.
#
# Backend serwera gry jest skromny w konfiguracji: czyta tylko LOG_LEVEL i NODE_ENV.
# Wartości poniżej są też domyślne w docker-compose.yml — plik .env służy do ich nadpisania.

# Poziom logów serwera (pino): trace|debug|info|warn|error. Produkcja: info.
LOG_LEVEL=info

# Tryb Node (wpływa m.in. na format logów/wydajność). Produkcja: production.
NODE_ENV=production
